# Optional OpenRouter configuration for explanation, chat, and AI decisioning.
# The app can still run its local scoring demo without this key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=credit-risk-explainer

# Explanation service.
EXPLANATION_MODEL=openai/gpt-oss-120b:free
EXPLANATION_TIMEOUT_SECONDS=20

# Chat service.
CHAT_MODEL=openai/gpt-oss-120b:free
CHAT_TIMEOUT_SECONDS=20
CHAT_MEMORY_MAX_TURNS=6
CHAT_MEMORY_TTL_SECONDS=1800

# Local model artifacts. These defaults assume the backend is started from backend/.
CREDIT_MODEL_PATH=app/models/credit_risk_lgbm.joblib
ANOMALY_MODEL_DIR=app/models/ae_agent
ANOMALY_MODEL_DEVICE=cpu

# Frontend API target. The frontend code also defaults to this value.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Present in backend settings for future provider support.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
